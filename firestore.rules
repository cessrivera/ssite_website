rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function requester() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function requesterExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isPrimaryAdmin() {
      return isSignedIn()
        && requesterExists()
        && requester().data.role == 'admin'
        && requester().data.email == 'admin@ssite.com';
    }
    
    // Allow public reads for site content
    match /announcements/{document=**} {
      allow read: if true;
      allow write: if isPrimaryAdmin();
      allow delete: if isPrimaryAdmin();
    }
    
    match /events/{document=**} {
      allow read: if true;
      allow write: if isPrimaryAdmin();
      allow delete: if isPrimaryAdmin();
    }
    
    match /officers/{document=**} {
      allow read: if true;
      allow write: if isPrimaryAdmin();
      allow delete: if isPrimaryAdmin();
    }
    
    match /polls/{document=**} {
      allow read: if true;
      allow write: if isPrimaryAdmin();
      allow delete: if isPrimaryAdmin();
    }
    
    match /pollVotes/{document=**} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.userId is string
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.pollId is string
                    && request.resource.data.optionIndex is int;
      allow update, delete: if isPrimaryAdmin();
    }
    
    match /members/{document=**} {
      allow read: if isPrimaryAdmin();
      allow create: if isPrimaryAdmin()
                    || (isSignedIn()
                        && request.resource.data.userId is string
                        && request.resource.data.userId == request.auth.uid
                        && request.resource.data.status == 'pending');
      allow update, delete: if isPrimaryAdmin();
    }

    match /memberStudentIds/{studentId} {
      allow read: if isPrimaryAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.userId is string
                    && request.resource.data.userId == request.auth.uid
                    && !exists(/databases/$(database)/documents/memberStudentIds/$(studentId));
      allow update, delete: if isPrimaryAdmin();
    }
    
    match /messages/{document=**} {
      allow read: if isPrimaryAdmin()
                  || (isSignedIn()
                      && (
                        (resource.data.senderUid is string && resource.data.senderUid == request.auth.uid)
                        || (resource.data.emailNormalized is string
                            && request.auth.token.email is string
                            && resource.data.emailNormalized == request.auth.token.email.lower())
                        || (resource.data.email is string
                            && request.auth.token.email is string
                            && (resource.data.email == request.auth.token.email
                                || resource.data.email == request.auth.token.email.lower()))
                        || (resource.data.senderAuthEmail is string
                            && request.auth.token.email is string
                            && (resource.data.senderAuthEmail == request.auth.token.email
                                || resource.data.senderAuthEmail == request.auth.token.email.lower()))
                       ));
      allow create: if isSignedIn();
      allow update, delete: if isPrimaryAdmin();
    }
    
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isPrimaryAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isPrimaryAdmin());
      allow delete: if isPrimaryAdmin();
    }
    
    match /eventRegistrations/{document=**} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isPrimaryAdmin();
    }
    
    match /notifications/{document=**} {
      allow read: if isSignedIn();
      allow write: if isPrimaryAdmin();
    }

    match /userNotifications/{notificationId} {
      allow read: if isPrimaryAdmin()
                  || (isSignedIn()
                      && (
                        (resource.data.userId is string && resource.data.userId == request.auth.uid)
                        || (resource.data.userEmail is string
                            && request.auth.token.email is string
                            && (resource.data.userEmail == request.auth.token.email
                                || resource.data.userEmail == request.auth.token.email.lower()))
                        || (resource.data.userEmailNormalized is string
                            && request.auth.token.email is string
                            && resource.data.userEmailNormalized == request.auth.token.email.lower())
                      ));
      allow create: if isPrimaryAdmin();
      allow update: if isPrimaryAdmin()
                    || (isSignedIn()
                        && (
                          (resource.data.userId is string && resource.data.userId == request.auth.uid)
                          || (resource.data.userEmail is string
                              && request.auth.token.email is string
                              && (resource.data.userEmail == request.auth.token.email
                                  || resource.data.userEmail == request.auth.token.email.lower()))
                          || (resource.data.userEmailNormalized is string
                              && request.auth.token.email is string
                              && resource.data.userEmailNormalized == request.auth.token.email.lower())
                        ));
      allow delete: if isPrimaryAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isPrimaryAdmin();
    }
  }
}
